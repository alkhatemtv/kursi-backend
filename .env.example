# ─────────────────────────────────────────────────────────────
# Kursi.io Backend — Environment Configuration
# Copy this file to `.env` and fill in your real values.
# Never commit `.env` to git!
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
# SQLite for local dev (file is created automatically).
# For production switch to PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./kursi.db

# ── Auth0 ───────────────────────────────────────────────────
# Get these from your Auth0 dashboard:
#   1. Go to https://manage.auth0.com → Applications → APIs
#   2. Create an API named "Kursi API" with identifier https://api.kursi.io
#   3. Copy the values below from your tenant settings
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_API_AUDIENCE=https://api.kursi.io
AUTH0_ALGORITHMS=RS256
# Custom claim namespace used to read user role/email from the token
# (set up via an Auth0 Action / Rule — see README)
AUTH0_NAMESPACE=https://kursi.io/

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# Add your production domain when you deploy.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500,https://kursi.io

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
